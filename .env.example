# ─── API ────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# ─── OpenAI (for LLM explainability agent) ─────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# ─── Kafka ──────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TRANSACTIONS=fraud.transactions.raw
KAFKA_TOPIC_SCORES=fraud.scores
KAFKA_TOPIC_DLQ=fraud.dlq
KAFKA_CONSUMER_GROUP=fraud-scorer

# ─── Spark ──────────────────────────────────────────────
SPARK_MASTER=local[*]
SPARK_APP_NAME=FraudDetectionStreaming

# ─── Database ───────────────────────────────────────────
DATABASE_URL=postgresql://fraud:fraud@localhost:5432/frauddb

# ─── Redis (drift monitoring cache) ────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Model ──────────────────────────────────────────────
MODEL_PATH=models/
AUTOENCODER_PATH=models/autoencoder.pt
XGBOOST_PATH=models/xgboost.json
THRESHOLD_AUTOENCODER=0.05
THRESHOLD_ENSEMBLE=0.5

# ─── Drift Alerting ─────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
DRIFT_PRECISION_THRESHOLD=0.05
DRIFT_RECALL_THRESHOLD=0.05
DRIFT_CHECK_INTERVAL_SECONDS=300
